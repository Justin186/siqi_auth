# ============================================================
# Siqi Auth - Auth Agent Docker 镜像
# 功能: 编译并打包 auth_agent 服务
# 架构: 多阶段构建（编译阶段 + 运行阶段）
# ============================================================

# ============================================================
# Stage 1: 编译环境 - 编译 brpc + auth_agent
# ============================================================
FROM ubuntu:22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

# 使用国内镜像源加速（如不需要可改回官方源）
RUN sed -i 's|archive.ubuntu.com|mirrors.aliyun.com|g' /etc/apt/sources.list && \
    sed -i 's|security.ubuntu.com|mirrors.aliyun.com|g' /etc/apt/sources.list

# 安装编译依赖
RUN apt-get update && apt-get install -y \
    cmake g++ make git pkg-config wget \
    libprotobuf-dev protobuf-compiler libprotoc-dev \
    libgflags-dev libleveldb-dev \
    libssl-dev zlib1g-dev \
    libmysqlcppconn-dev \
    && rm -rf /var/lib/apt/lists/*

# 编译 brpc（从 GitHub 拉源码）
WORKDIR /opt
RUN git clone --depth 1 --branch 1.10.0 https://github.com/apache/brpc.git && \
    cd brpc && mkdir build && cd build && \
    cmake -DCMAKE_BUILD_TYPE=Release \
          -DWITH_GLOG=OFF \
          -DWITH_THRIFT=OFF \
          .. && \
    make -j$(nproc) && \
    make install && \
    ldconfig

# 拷贝 siqi_auth 源码
WORKDIR /app
COPY include/ /app/include/
COPY src/ /app/src/
COPY proto/ /app/proto/
COPY test/ /app/test/
COPY CMakeLists.txt /app/

# 使用容器内的 protoc 重新生成 pb 代码，避免宿主机与镜像内 protobuf 版本不一致
RUN protoc --proto_path=/app/proto --cpp_out=/app/src /app/proto/auth.proto && \
    cp /app/src/auth.pb.h /app/include/auth.pb.h && \
    rm -f /app/src/auth.pb.h

# 编译 auth_agent
RUN mkdir -p build && cd build && \
    cmake -DCMAKE_BUILD_TYPE=Release .. && \
    make -j$(nproc) auth_agent

# ============================================================
# Stage 2: 运行环境 - 只保留必要运行时依赖
# ============================================================
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# 使用国内镜像源加速（如不需要可改回官方源）
RUN sed -i 's|archive.ubuntu.com|mirrors.aliyun.com|g' /etc/apt/sources.list && \
    sed -i 's|security.ubuntu.com|mirrors.aliyun.com|g' /etc/apt/sources.list

# 安装运行时依赖
# 增加 curl 方便在 docker-compose 中做 healthcheck
RUN apt-get update && apt-get install -y --no-install-recommends \
    libprotobuf23 \
    libmysqlcppconn7v5 \
    libssl3 \
    libleveldb1d \
    libgflags2.2 \
    libsnappy1v5 \
    libmysqlclient-dev \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 从构建阶段复制 brpc 动态库
COPY --from=builder /usr/local/lib/libbrpc.so* /usr/local/lib/
RUN ldconfig

# 复制编译好的 auth_agent 二进制
COPY --from=builder /app/build/auth_agent /usr/local/bin/auth_agent

# 暴露 agent 服务端口（实际监听端口由启动参数决定）
EXPOSE 8001

ENTRYPOINT ["auth_agent"]
